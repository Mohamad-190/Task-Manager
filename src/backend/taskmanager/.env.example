# Kopiere diese Datei nach .env und fuelle die Werte aus.
# Die .env-Datei ist gitignored.

# Initialer Admin-Account (wird beim ersten Start angelegt, falls noch kein Admin existiert)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
ADMIN_PHONE=+49000000000

# JWT-Secret: mindestens 32 Zeichen (256 Bit) fuer HS256.
# Generieren z.B. mit: openssl rand -base64 48
JWT_SECRET=please-generate-a-long-random-secret-at-least-32-chars

# Token-Lebensdauer in Millisekunden (Default: 24h)
JWT_EXPIRATION_MS=86400000
